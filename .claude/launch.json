{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Netlify Dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["netlify", "dev", "--port", "8888"],
      "port": 8888
    },
    {
      "name": "Static Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "3000", "--bind", "127.0.0.1"],
      "port": 3000
    }
  ]
}
