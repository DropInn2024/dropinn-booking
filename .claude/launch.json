{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "Netlify Dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["netlify-cli", "dev", "--port", "8888"],
      "port": 8888
    }
  ]
}
